uniform sampler2D SCREEN_TEXTURE;

void fragment() {
    highp vec4 color = texture(SCREEN_TEXTURE, UV);
    
    highp mat3 m = mat3(
        vec3(0.625, 0.375, 0.000),
        vec3(0.700, 0.300, 0.000),
        vec3(0.000, 0.300, 0.700)
    );
    
    highp vec3 dogVision = color.rgb * m;
    
    float intensity = 0.6;
    highp vec3 result = mix(color.rgb, dogVision, intensity);
    
    COLOR = vec4(result, 1.0);
}