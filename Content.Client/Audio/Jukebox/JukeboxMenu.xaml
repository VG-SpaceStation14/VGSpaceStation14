<ui:FancyWindow xmlns="https://spacestation14.io" 
                xmlns:ui="clr-namespace:Content.Client.UserInterface.Controls"
                xmlns:cc="clr-namespace:Content.Client.Administration.UI.CustomControls"
                MinSize="480 420"
                SetSize="480 420"
                Title="{Loc 'jukebox-menu-title'}">
    <BoxContainer Margin="6" Orientation="Vertical" SeparationOverride="4">
        
        <!-- Поиск -->
        <LineEdit Name="SearchBar" PlaceHolder="{Loc 'jukebox-menu-search'}" HorizontalExpand="True" />
        
        <!-- Плейлист -->
        <ItemList Name="MusicList" SelectMode="Button" 
                  HorizontalExpand="True" VerticalExpand="True" 
                  SizeFlagsStretchRatio="8" Margin="0 2 0 2" />
        
        <!-- Инфо о треке -->
        <BoxContainer Orientation="Vertical" Margin="0 2 0 2">
            <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
                <Label Name="SongName" Text="---" ClipText="True" HorizontalExpand="True" />
                <Label Name="DurationLabel" Text="00:00 / 00:00" HorizontalAlignment="Right" MinWidth="90" />
            </BoxContainer>
            <Slider Name="PlaybackSlider" HorizontalExpand="True" />
        </BoxContainer>
        
        <cc:HSeparator Color="#4972A1" Margin="0 2 0 2" />
        
        <!-- Плеер -->
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True" SeparationOverride="4" HorizontalAlignment="Center">
            <Button Name="PrevButton" Text="⏮" StyleClasses="ButtonSquare" ToolTip="{Loc 'jukebox-menu-buttonprev'}" />
            <Button Name="PlayButton" Text="▶" StyleClasses="ButtonSquare" MinWidth="50" />
            <Button Name="StopButton" Text="⏹" StyleClasses="ButtonSquare" ToolTip="{Loc 'jukebox-menu-buttonstop'}" />
            <Button Name="NextButton" Text="⏭" StyleClasses="ButtonSquare" ToolTip="{Loc 'jukebox-menu-buttonnext'}" />
        </BoxContainer>
        
        <!-- Режимы -->
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True" SeparationOverride="4" HorizontalAlignment="Center">
            <Button Name="RepeatButton" Text="{Loc 'jukebox-menu-buttonrepeat-off'}" 
                    ToggleMode="True" StyleClasses="ButtonSquare" MinWidth="80" />
            <Button Name="ShuffleButton" Text="{Loc 'jukebox-menu-buttonshuffle'}" 
                    ToggleMode="True" StyleClasses="ButtonSquare" MinWidth="80" />
        </BoxContainer>
        
        <!-- Громкость -->
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True" SeparationOverride="6">
            <Label Name="VolumeLabel" Text="{Loc 'jukebox-menu-volume'}" MinWidth="60" />
            <Slider Name="VolumeSlider" HorizontalExpand="True" />
            <Label Name="VolumeNumberLabel" Text="0%" MinWidth="45" HorizontalAlignment="Right" />
        </BoxContainer>
        
    </BoxContainer>
</ui:FancyWindow>