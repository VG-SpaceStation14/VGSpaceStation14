<Control
    xmlns="https://spacestation14.io"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls">
    <BoxContainer Name="VBox" Orientation="Vertical">
        <controls:NanoHeading Name="Header" Text="{Loc 'lobby-character-preview-panel-header'}">
        </controls:NanoHeading>
        <BoxContainer Name="Loaded" Orientation="Vertical"
                      Visible="False">
            <RichTextLabel Name="Summary" HorizontalAlignment="Center" Margin="3 3" 
                           MaxWidth="280"/>
            <BoxContainer Name="CharacterSelectorRow" Orientation="Horizontal" 
                          HorizontalAlignment="Center" Margin="3 5">
                <Button Name="LeftCharacterButton" MinSize="90 120" Visible="False"
                        StyleClasses="OpenRight" Margin="0 0 2 0"
                        VerticalAlignment="Center">
                    <BoxContainer Orientation="Vertical" HorizontalAlignment="Center"
                                  VerticalAlignment="Center" SeparationOverride="2">
                        <SpriteView Name="LeftSpriteView" Scale="3.75 3.75" 
                                    OverrideDirection="South" 
                                    HorizontalAlignment="Center"
                                    SetSize="84 84"/>
                        <Label Name="LeftCharName" HorizontalAlignment="Center"
                               ClipText="True" MaxWidth="80" Margin="0 2"/>
                    </BoxContainer>
                </Button>
                
                <PanelContainer Name="CenterCharacterPanel" MinSize="112 140"
                                StyleClasses="AngleRect">
                    <BoxContainer Orientation="Vertical" HorizontalAlignment="Center"
                                  VerticalAlignment="Center">
                        <BoxContainer Name="ViewBox" Orientation="Horizontal" 
                                      HorizontalAlignment="Center">
                        </BoxContainer>
                    </BoxContainer>
                </PanelContainer>
                
                <Button Name="RightCharacterButton" MinSize="90 120" Visible="False"
                        StyleClasses="OpenLeft" Margin="2 0 0 0"
                        VerticalAlignment="Center">
                    <BoxContainer Orientation="Vertical" HorizontalAlignment="Center"
                                  VerticalAlignment="Center" SeparationOverride="2">
                        <SpriteView Name="RightSpriteView" Scale="3.75 3.75" 
                                    OverrideDirection="South"
                                    HorizontalAlignment="Center"
                                    SetSize="84 84"/>
                        <Label Name="RightCharName" HorizontalAlignment="Center"
                               ClipText="True" MaxWidth="80" Margin="0 2"/>
                    </BoxContainer>
                </Button>
            </BoxContainer>
            <controls:VSpacer/>
        </BoxContainer>
        <Label Name="Unloaded" Text="{Loc 'lobby-character-preview-panel-unloaded-preferences-label'}"/>
    </BoxContainer>
</Control>