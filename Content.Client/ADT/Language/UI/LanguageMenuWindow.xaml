<ui:FancyWindow xmlns="https://spacestation14.io"
                xmlns:ui="clr-namespace:Content.Client.UserInterface.Controls"
                Title="{Loc 'language-menu-window-title'}"
                SetSize="450 500"
                MinSize="350 400">

    <BoxContainer Orientation="Vertical" SeparationOverride="8" Margin="8">

        <!-- Заголовок: текущий язык и количество известных языков -->
        <PanelContainer StyleClasses="LanguagesHeaderPanel">
            <BoxContainer Orientation="Vertical" Margin="12 10">
                <BoxContainer Orientation="Horizontal" Margin="0 0 0 8">
                    <Label Name="CurrentLanguageLabel"
                           StyleClasses="LanguagesTitleLabel"/>
                    <Control HorizontalExpand="True"/>
                    <Label Name="LanguagesCountLabel"
                           StyleClasses="LanguagesStatLabel"/>
                </BoxContainer>
            </BoxContainer>
        </PanelContainer>

        <!-- Поиск -->
        <PanelContainer StyleClasses="LanguagesSearchBar">
            <LineEdit Name="SearchBar"
                      PlaceHolder="{Loc 'language-menu-search-placeholder'}"
                      StyleClasses="LanguagesSearchInput"
                      Margin="10 8"/>
        </PanelContainer>

        <!-- Список языков -->
        <ScrollContainer HorizontalExpand="True" VerticalExpand="True" HScrollEnabled="False">
            <BoxContainer Name="OptionsList" Orientation="Vertical" SeparationOverride="4" Margin="0 0 4 0"/>
        </ScrollContainer>

        <!-- Футер -->
        <PanelContainer StyleClasses="LanguagesFooterPanel">
            <Label Text="{Loc 'language-menu-footer-hint'}" StyleClasses="LanguagesFooterText" Margin="10 6"/>
        </PanelContainer>
    </BoxContainer>
</ui:FancyWindow>