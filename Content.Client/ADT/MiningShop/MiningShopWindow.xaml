<DefaultWindow
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client.ADT.MiningShop"
    xmlns:cc="clr-namespace:Content.Client.Administration.UI.CustomControls"
    MinSize="520 615"
    SetSize="520 615"
    Resizable="True">
    <BoxContainer Orientation="Vertical" SeparationOverride="4" Margin="8">
        
        <!-- Header: Points and Search -->
        <BoxContainer Orientation="Horizontal" SeparationOverride="8">
            <Label Name="PointsLabel" Access="Public" Text="Очки: 0" StyleClasses="LabelHeading" MinWidth="100" />
            <Control HorizontalExpand="True" />
            <LineEdit Name="Search" Access="Public" PlaceHolder="Поиск..." HorizontalExpand="True" MinWidth="180" />
        </BoxContainer>
        
        <!-- Cart section -->
        <BoxContainer Orientation="Vertical" Margin="0 2 0 2">
            <BoxContainer Orientation="Horizontal">
                <RichTextLabel Name="YourPurchases" Access="Public" MaxWidth="400" />
                <Control HorizontalExpand="True" />
            </BoxContainer>
            <BoxContainer Orientation="Horizontal" HorizontalExpand="True" SeparationOverride="6" Margin="0 4 0 0">
                <Label Name="TotalCostLabel" Access="Public" Text="Сумма: 0 P" StyleClasses="LabelHeading" Visible="False" />
                <Control HorizontalExpand="True" />
                <Button Name="ClearCart" Access="Public" Text="Очистить" MaxWidth="90" Visible="False" StyleClasses="ButtonSquare ButtonColorRed" />
                <Button Name="Express" Access="Public" Text="Экспресс" MinWidth="90" Visible="False" StyleClasses="ButtonSquare ButtonColorGreen" />
            </BoxContainer>
        </BoxContainer>
        
        <cc:HSeparator Color="#4972A1" Margin="0 4 0 4" />
        
        <!-- Category buttons -->
        <BoxContainer Orientation="Vertical" HorizontalExpand="True" Margin="0 2 0 2">
            <BoxContainer Orientation="Horizontal" Name="CategoryButtonsRow1" Access="Public" SeparationOverride="4" HorizontalExpand="True" />
            <BoxContainer Orientation="Horizontal" Name="CategoryButtonsRow2" Access="Public" SeparationOverride="4" HorizontalExpand="True" Margin="0 4 0 0" />
        </BoxContainer>
        
        <!-- Items scroll -->
        <ScrollContainer HorizontalExpand="True" VerticalExpand="True" Margin="0 4 0 0">
            <BoxContainer Orientation="Vertical" Name="Sections" Access="Public" SeparationOverride="4" />
        </ScrollContainer>
        
    </BoxContainer>
</DefaultWindow>