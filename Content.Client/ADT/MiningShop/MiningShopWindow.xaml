<DefaultWindow
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client.ADT.MiningShop"
    xmlns:cc="clr-namespace:Content.Client.Administration.UI.CustomControls"
    MinSize="700 750"
    SetSize="700 750"
    Resizable="False">
    <BoxContainer Orientation="Vertical">
        <BoxContainer Orientation="Horizontal">
            <Label Text="Search" Align="Left" />
            <LineEdit Name="Search" Access="Public" HorizontalExpand="True" Margin="10 0 0 0" />
            <Control HorizontalExpand="True" SizeFlagsStretchRatio="0.25" />
            <Label Name="PointsLabel" Access="Public" HorizontalExpand="True" Align="Right" />
        </BoxContainer>
        
        <!-- Order section -->
        <BoxContainer Orientation="Vertical" Margin="0 0 0 5">
            <BoxContainer Orientation="Horizontal">
                <RichTextLabel Name="YourPurchases" Access="Public" MaxWidth="1000" />
                <Control HorizontalExpand="True" />
            </BoxContainer>
            <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
                <Label Name="TotalCostLabel" Access="Public" Text="Сумма: 0 P" StyleClasses="LabelHeading" MinWidth="100" Visible="False" />
                <Control HorizontalExpand="True" />
                <!-- VG-Tweak: both buttons now have conditional visibility and colors -->
                <Button Name="ClearCart" Access="Public" Text="Очистить корзину" MaxWidth="150" Visible="False" Margin="0 0 5 0" StyleClasses="ButtonSquare ButtonColorRed" />
                <Button Name="Express" Access="Public" Text="Экспресс доставка" MinWidth="150" Visible="False" StyleClasses="ButtonSquare ButtonColorGreen" />
            </BoxContainer>
        </BoxContainer>
        
        <!-- Category buttons in two rows -->
        <BoxContainer Orientation="Vertical" HorizontalExpand="True" Margin="0 5 0 5">
            <BoxContainer Orientation="Horizontal" Name="CategoryButtonsRow1" Access="Public" SeparationOverride="5" HorizontalExpand="True" />
            <BoxContainer Orientation="Horizontal" Name="CategoryButtonsRow2" Access="Public" SeparationOverride="5" HorizontalExpand="True" Margin="5 0 0 0" />
        </BoxContainer>
        
        <ScrollContainer HorizontalExpand="True" VerticalExpand="True">
            <BoxContainer Orientation="Vertical" Name="Sections" Access="Public" />
        </ScrollContainer>
    </BoxContainer>
</DefaultWindow>