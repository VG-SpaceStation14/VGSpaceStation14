<cc:MiningShopEntry
    xmlns="https://spacestation14.io"
    xmlns:cc="clr-namespace:Content.Client.ADT.MiningShop"
    xmlns:graphics="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    HorizontalExpand="True">
    <PanelContainer Name="BackgroundPanel" Access="Public" HorizontalExpand="True" VerticalExpand="True" Margin="2">
        <PanelContainer.PanelOverride>
            <graphics:StyleBoxFlat BackgroundColor="#162031" BorderColor="#4972A1" BorderThickness="1" />
        </PanelContainer.PanelOverride>
        <!-- VG-Tweak: simplified layout without description text -->
        <BoxContainer Orientation="Horizontal" Margin="2">
            <LayeredTextureRect Name="Texture" Access="Public"
                                HorizontalExpand="False" VerticalExpand="False"
                                MinSize="24 24" SetSize="24 24" Margin="2 0 2 0" />
            <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True" Margin="2 0 0 0">
                <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
                    <!-- VG-Tweak: increased left margin to prevent text overlapping with icon -->
                    <Label Name="ItemName" Access="Public" StyleClasses="LabelHeading" MinWidth="150" Margin="5 0 0 0" />
                    <Control HorizontalExpand="True" />
                    <Label Name="Price" Access="Public" StyleClasses="LabelSubText" Margin="0 0 2 0" MinWidth="45" />
                </BoxContainer>
                <!-- Description removed from here -->
            </BoxContainer>
            <Button Name="BuyButton" Access="Public" Text="Купить" MinWidth="60" StyleClasses="ButtonSquare" Margin="2" />
            <!-- VG-Tweak: add tooltip button back -->
            <Button Name="TooltipButton" Access="Public" Text="?" MinWidth="20" StyleClasses="ButtonSquare" Margin="2" />
        </BoxContainer>
    </PanelContainer>
</cc:MiningShopEntry>