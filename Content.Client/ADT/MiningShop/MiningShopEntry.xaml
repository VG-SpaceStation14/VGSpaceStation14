<cc:MiningShopEntry
    xmlns="https://spacestation14.io"
    xmlns:cc="clr-namespace:Content.Client.ADT.MiningShop"
    xmlns:graphics="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    HorizontalExpand="True">
    <PanelContainer Name="BackgroundPanel" Access="Public" HorizontalExpand="True" Margin="1">
        <PanelContainer.PanelOverride>
            <graphics:StyleBoxFlat BackgroundColor="#162031" BorderColor="#4972A1" BorderThickness="1" />
        </PanelContainer.PanelOverride>
        <BoxContainer Orientation="Horizontal" Margin="4 2 4 2">
            <LayeredTextureRect Name="Texture" Access="Public"
                                HorizontalExpand="False" VerticalExpand="False"
                                MinSize="24 24" SetSize="24 24" Margin="0" />
            <Label Name="ItemName" Access="Public" MinWidth="200" Margin="8 0 0 0" ClipText="True" VerticalAlignment="Center" />
            <Control HorizontalExpand="True" />
            <Label Name="Price" Access="Public" StyleClasses="LabelSubText" MinWidth="45" Align="Right" VerticalAlignment="Center" />
            <Button Name="TooltipButton" Access="Public" Text="?" MinWidth="18" StyleClasses="ButtonSquare" Margin="4 0 2 0" />
            <Button Name="BuyButton" Access="Public" Text="Купить" MinWidth="55" StyleClasses="ButtonSquare" />
        </BoxContainer>
    </PanelContainer>
</cc:MiningShopEntry>