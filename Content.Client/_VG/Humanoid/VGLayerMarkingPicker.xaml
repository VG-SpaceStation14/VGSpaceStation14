<BoxContainer xmlns="https://spacestation14.io"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              Orientation="Vertical"
              HorizontalExpand="True">
    <LineEdit Name="SearchBar" PlaceHolder="{Loc 'markings-search'}" HorizontalExpand="True" Margin="4" />
    <ScrollContainer Name="SelectionScroll" VerticalExpand="True" HorizontalExpand="True">
        <BoxContainer Name="ItemsContainer" Orientation="Vertical" HorizontalExpand="True" />
    </ScrollContainer>
    <BoxContainer Name="OrderingContainer" Orientation="Vertical" Visible="False" />
    <BoxContainer HorizontalExpand="True" Margin="4">
        <Label Name="MarkingsStatus" HorizontalExpand="True" />
        <Button Name="ReorderButton" ToggleMode="True" Text="{Loc 'markings-reorder'}" />
    </BoxContainer>
</BoxContainer>