<cartridges:NavigatorUiFragment xmlns:cartridges="clr-namespace:Content.Client._VG.CartridgeLoader.Cartridges"
                                xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                                xmlns="https://spacestation14.io" 
                                Margin="4" 
                                Orientation="Vertical"
                                MinHeight="620"
                                MaxHeight="650">
    <BoxContainer Orientation="Vertical" 
                  HorizontalExpand="True" 
                  VerticalExpand="True"
                  Margin="4">
        <controls:StripeBack Name="StationNameContainer" MinHeight="30">
            <PanelContainer>
                <Label Name="StationNameLabel" 
                       Align="Center" 
                       Text="{Loc 'navigator-cartridge-loading'}" 
                       StyleClasses="SubText"/>
            </PanelContainer>
        </controls:StripeBack>
        <PanelContainer Name="NavMapContainer" 
                        HorizontalExpand="True" 
                        VerticalExpand="True" 
                        Margin="4"
                        MinHeight="560"
                        MaxHeight="560">
        </PanelContainer>
    </BoxContainer>
</cartridges:NavigatorUiFragment>