<Control xmlns="https://spacestation14.io"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:graphics="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
         x:Class="Content.Client._VG.Lobby.UI.VGCharacterSetupWindowGui"
         VerticalExpand="True">
    <BoxContainer Orientation="Horizontal" SeparationOverride="12" Margin="8" VerticalExpand="True">
        <!-- ЛЕВАЯ КОЛОНКА -->
        <BoxContainer Orientation="Vertical" SeparationOverride="8" MinSize="240 0">
            <!-- Тёмная панель имени -->
            <PanelContainer StyleClasses="BackgroundDark">
                <PanelContainer.PanelOverride>
                    <graphics:StyleBoxFlat BackgroundColor="#1A1A1A"
                                           ContentMarginLeftOverride="6"
                                           ContentMarginTopOverride="6"
                                           ContentMarginRightOverride="6"
                                           ContentMarginBottomOverride="6" />
                </PanelContainer.PanelOverride>
                <BoxContainer Orientation="Vertical">
                    <BoxContainer Orientation="Horizontal" VerticalExpand="True">
                        <Label Text="{Loc 'humanoid-profile-editor-name-label'}" VerticalAlignment="Center" />
                        <Control Name="NameEditContainer" HorizontalExpand="True" VerticalAlignment="Center" Margin="5 0 0 0" />
                    </BoxContainer>
                    <BoxContainer Orientation="Horizontal" Margin="0 4">
                        <Button Name="NameRandomize" Text="{Loc 'humanoid-profile-editor-name-random-button'}" HorizontalExpand="True" />
                    </BoxContainer>
                    <RichTextLabel Name="WarningLabel" MaxWidth="425" Margin="0 4" />
                    <Button Name="RandomizeEverythingButton" HorizontalExpand="True"
                            Text="{Loc 'humanoid-profile-editor-randomize-everything-button'}" />
                </BoxContainer>
            </PanelContainer>

            <!-- Панель кнопок кастомизации (тёмный фон) -->
            <PanelContainer StyleClasses="BackgroundDark">
                <PanelContainer.PanelOverride>
                    <graphics:StyleBoxFlat BackgroundColor="#1A1A1A"
                                           ContentMarginLeftOverride="6"
                                           ContentMarginTopOverride="4"
                                           ContentMarginRightOverride="6"
                                           ContentMarginBottomOverride="4" />
                </PanelContainer.PanelOverride>
                <BoxContainer Orientation="Horizontal" HorizontalExpand="True" SeparationOverride="4">
                    <!-- Кнопка КПК слева -->
                    <PanelContainer>
                        <PanelContainer.PanelOverride>
                            <graphics:StyleBoxFlat BackgroundColor="#2D2D2D"
                                                   ContentMarginLeftOverride="4"
                                                   ContentMarginTopOverride="4"
                                                   ContentMarginRightOverride="4"
                                                   ContentMarginBottomOverride="4" />
                        </PanelContainer.PanelOverride>
                        <TextureButton Name="PdaWallpaperButton"
                                       SetSize="55 55"
                                       HorizontalAlignment="Left"
                                       ToolTip="{Loc 'pda-wallpaper-title'}" />
                    </PanelContainer>
                    
                    <!-- Растягивающийся отступ, чтобы прижать кнопки к правому краю -->
                    <Control HorizontalExpand="True" />
                    
                    <!-- VG-Tweak Start: Кнопки глобальных лодаутов (прижаты к правому краю, порядок: носки, бельё, футболки) -->
                    <PanelContainer>
                        <PanelContainer.PanelOverride>
                            <graphics:StyleBoxFlat BackgroundColor="#2D2D2D"
                                                   ContentMarginLeftOverride="4"
                                                   ContentMarginTopOverride="4"
                                                   ContentMarginRightOverride="4"
                                                   ContentMarginBottomOverride="4" />
                        </PanelContainer.PanelOverride>
                        <TextureButton Name="GlobalSocksButton"
                                       SetSize="55 55"
                                       HorizontalAlignment="Left"
                                       ToolTip="{Loc 'loadout-group-socks-adt'}" />
                    </PanelContainer>
                    <PanelContainer>
                        <PanelContainer.PanelOverride>
                            <graphics:StyleBoxFlat BackgroundColor="#2D2D2D"
                                                   ContentMarginLeftOverride="4"
                                                   ContentMarginTopOverride="4"
                                                   ContentMarginRightOverride="4"
                                                   ContentMarginBottomOverride="4" />
                        </PanelContainer.PanelOverride>
                        <TextureButton Name="GlobalBottomButton"
                                       SetSize="55 55"
                                       HorizontalAlignment="Left"
                                       ToolTip="{Loc 'loadout-group-bottom-adt'}" />
                    </PanelContainer>
                    <PanelContainer>
                        <PanelContainer.PanelOverride>
                            <graphics:StyleBoxFlat BackgroundColor="#2D2D2D"
                                                   ContentMarginLeftOverride="4"
                                                   ContentMarginTopOverride="4"
                                                   ContentMarginRightOverride="4"
                                                   ContentMarginBottomOverride="4" />
                        </PanelContainer.PanelOverride>
                        <TextureButton Name="GlobalTopButton"
                                       SetSize="55 55"
                                       HorizontalAlignment="Left"
                                       ToolTip="{Loc 'loadout-group-top-adt'}" />
                    </PanelContainer>
                    <!-- VG-Tweak End -->
                </BoxContainer>
            </PanelContainer>

            <!-- Превью (чёрная панель, размер не меняется) с кнопкой одежды в углу -->
            <PanelContainer Name="PreviewPanel" MinSize="220 340" StyleClasses="AngleRect">
                <PanelContainer.PanelOverride>
                    <graphics:StyleBoxFlat BackgroundColor="#000000"
                                           BorderColor="#FFFFFF"
                                           BorderThickness="3"
                                           ContentMarginLeftOverride="4"
                                           ContentMarginTopOverride="4"
                                           ContentMarginRightOverride="4"
                                           ContentMarginBottomOverride="4" />
                </PanelContainer.PanelOverride>
                
                <!-- Основной контент превью -->
                <BoxContainer Name="PreviewContainer" Orientation="Vertical"
                              HorizontalAlignment="Center" VerticalAlignment="Center">
                    <BoxContainer Name="CharacterPreviewContent" Orientation="Vertical"
                                  HorizontalAlignment="Center" VerticalAlignment="Center">
                        <SpriteView Name="PreviewSprite" Scale="5 5" OverrideDirection="South"
                                    HorizontalAlignment="Center" SetSize="180 180" />
                        <BoxContainer Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 5">
                            <Button Name="RotateLeft" Text="◀" StyleClasses="OpenRight" />
                            <Button Name="RotateRight" Text="▶" StyleClasses="OpenLeft" />
                        </BoxContainer>
                    </BoxContainer>
                    <PanelContainer Name="PdaPreviewContent" Visible="False" MinSize="200 280"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                        <PanelContainer.PanelOverride>
                            <graphics:StyleBoxFlat BackgroundColor="#25252a" />
                        </PanelContainer.PanelOverride>
                    </PanelContainer>
                </BoxContainer>

                <!-- Кнопка переключения одежды в правом верхнем углу панели превью -->
                <TextureButton Name="ClothesToggleButton"
                        TexturePath="/Textures/Interface/VerbIcons/vv.svg.192dpi.png"
                        SetSize="32 32"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0 4 4 0"
                        ToolTip="{Loc 'humanoid-profile-editor-clothing'}" />
            </PanelContainer>

            <!-- Панель выбора обоев КПК (горизонтальный скролл) -->
            <PanelContainer Name="PdaWallpaperPanel" StyleClasses="BackgroundDark" Visible="False">
                <PanelContainer.PanelOverride>
                    <graphics:StyleBoxFlat BackgroundColor="#1A1A1A"
                                           ContentMarginLeftOverride="6"
                                           ContentMarginTopOverride="6"
                                           ContentMarginRightOverride="6"
                                           ContentMarginBottomOverride="6" />
                </PanelContainer.PanelOverride>
                <BoxContainer Orientation="Vertical">
                    <Label Text="{Loc 'pda-wallpaper-title'}" Margin="0 0 0 4" />
                    <ScrollContainer HScrollEnabled="True" VScrollEnabled="False" MinHeight="140">
                        <BoxContainer Name="PdaWallpaperButtons" Orientation="Horizontal" SeparationOverride="6" />
                    </ScrollContainer>
                </BoxContainer>
            </PanelContainer>
        </BoxContainer>

        <!-- ПРАВАЯ КОЛОНКА -->
        <BoxContainer Orientation="Vertical" SeparationOverride="8" HorizontalExpand="True" VerticalExpand="True">
            <BoxContainer Orientation="Horizontal" SeparationOverride="4">
                <Button Name="SaveButton" Text="{Loc 'humanoid-profile-editor-save-button'}" StyleClasses="ButtonBig" />
                <Button Name="ResetButton" Text="{Loc 'humanoid-profile-editor-reset-button'}" StyleClasses="ButtonBig" />
                <Button Name="ImportButton" Text="{Loc 'humanoid-profile-editor-import-button'}" StyleClasses="ButtonBig" />
                <Button Name="ExportButton" Text="{Loc 'humanoid-profile-editor-export-button'}" StyleClasses="ButtonBig" />
                
                <Control MinSize="10 0" />
                
                <Button Name="StatsButton" Text="{Loc 'character-setup-gui-character-setup-stats-button'}" />
                <Button Name="AdminRemarksButton" Text="{Loc 'character-setup-gui-character-setup-adminremarks-button'}" />
                
                <Control MinSize="10 0" />
                
                <Control HorizontalExpand="True" />
                
                <Button Name="CreateCharacterButton" Text="+" MinSize="32 0" StyleClasses="OpenRight" />
                <OptionButton Name="CharacterSelector" HorizontalExpand="True" MinSize="100 0" StyleClasses="OpenBoth" />
                <Button Name="DeleteCharacterButton" Text="×" MinSize="32 0" StyleClasses="OpenLeft" />
            </BoxContainer>
            <Control Name="EditorContainer" HorizontalExpand="True" VerticalExpand="True" />
        </BoxContainer>
    </BoxContainer>
</Control>